CREATE TABLE REGIONS ( REGION_ID INT (2) , REGION_NAME VARCHAR (25));

CREATE TABLE COUNTRIES (COUNTRY_ID VARCHAR(2),COUNTRY_NAME VARCHAR(40),REGION_ID INT(2));

CREATE TABLE LOCATIONS (LOCATION_ID INT(4),STREET_ADDRESS VARCHAR(40),POSTAL_CODE VARCHAR(40),CITY VARCHAR(30),STATE_PROVINCE VARCHAR(25),COUNTRY_ID VARCHAR(2));

CREATE TABLE DEPARTMENTS (DEPARTMENT_ID INT(4),DEPARTMENT_NAME VARCHAR(30),MANAGER_ID INT(8),LOCATION_ID INT(4));

CREATE JOBS (JOB_ID VARCHAR(10),JOB_TITLE VARCHAR(35),MIN_SALARY INT(8,2),MAX_SALARY INT(8,2));

CREATE TABLE JOB_HISTORY (EMPLOYEE_ID INT(6), START_DATE DATE, END_DATE DATE, JOB_ID VARCHAR(10), DEPARTMENT_ID INT(4));

CREATE TABLE EMPLOYEES (EMPLOYEE_ID INT(6),FIRST_NAME VARCHAR(20),LAST_NAME CHAR(25), EMAIL VARCHAR(25), PHONE_NUMBER VARCHAR(20), HIRE_DATE DATE, JOB_ID VARCHAR(10), SALARY INT(8,2),COMMISSION_PCT INT(2,2),MANAGER_ID INT(4), DEPARTMENT_ID INT(4));
