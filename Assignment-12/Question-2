do $$
declare
  a numeric := 10;  
  b numeric := 5;
begin
  raise notice 'sum=%', a+b;
  raise notice 'diff=%', a-b;
  raise notice 'product=%', a*b;
  if b != 0 then 
    raise notice 'quotient=%', a/b;
  else 
    raise notice 'quotient=cannot divide by 0';
  end if;
end $$;


