do $$
declare
  a numeric := 10;  
  b numeric := 20;
  c numeric := 15;
begin
  if a > b and a > c then 
    raise notice 'a = % is greatest', a;
  elsif b > a and b > c then 
    raise notice 'b = % is greatest', b;
  else 
    raise notice 'c = % is greatest', c;
  end if;
end $$;


