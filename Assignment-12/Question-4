do $$
declare
  num numeric := 10;  
begin
  if num > 0 then 
    raise notice 'number % is positive', num;
  elsif num < 0 then 
    raise notice 'number % is negative', num;
  else 
    raise notice 'number % is zero', num;
  end if;
end $$;


