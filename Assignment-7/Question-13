SELECT e.ename, p.pname, SUM(w.hours) AS total_hours FROM employee e INNER JOIN work_on w ON e.esrno = w.esrno INNER JOIN project p ON w.pno = p.pnumber GROUP BY e.esrno, e.ename, p.pname ORDER BY total_hours ;

