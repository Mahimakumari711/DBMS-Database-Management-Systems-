SELECT m.ename AS manager_name, SUM(w.hours) AS total_hours FROM employee m INNER JOIN employee e ON m.esrno = e.mgrsrno INNER JOIN work_on w ON e.esrno = w.esrno GROUP BY m.esrno, m.ename ORDER BY total_hours ;

