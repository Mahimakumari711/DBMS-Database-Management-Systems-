Method  3 :

SELECT e.ename, e.esrno, e.bdate, e.address, e.sex, e.salary, d.dname, dl.dlocation, p.pname, p.plocation, COUNT(w.pno) as work_entries, ROUND(SUM(w.hours)::numeric, 2) as total_hours, STRING_AGG(ROUND(w.hours::numeric, 2)::text, ' | ') as all_hoursFROM employee e LEFT JOIN department d ON e.dno = d.dnumber LEFT JOIN dept_locations dl ON e.dno = dl.dnumber LEFT JOIN work_on w ON e.esrno = w.esrno LEFT JOIN project p ON w.pno = p.pnumber WHERE e.ename = 'MEENAKSHI' GROUP BY e.ename, e.esrno, e.bdate, e.address, e.sex, e.salary, d.dname, dl.dlocation, p.pname, p.plocation;

