Method 1 :

SELECT DISTINCT 
e.ename, e.esrno, e.bdate, e.address, e.sex, e.salary, e.mgrsrno, e.dno, d.dname, d.mgrsrno, d.mgrstartd, p.pname, p.pnumber, p.plocation, w.pno, w.hours,dl.dlocation FROM employee e LEFT JOIN department d ON e.dno = d.dnumber LEFT JOIN project p ON d.dnumber = p.dnum LEFT JOIN work_on w ON e.esrno = w.esrno LEFT JOIN dept_locations dl ON d.dnumber = dl.dnumber WHERE e.ename = 'MEENAKSHI';

